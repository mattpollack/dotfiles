# Brewfile for macOS
# Install with: brew bundle --file=~/home-manager/Brewfile
#
# This file lists all the packages needed for a fresh macOS setup
# without Nix/home-manager. Use this in combination with quick-setup.sh
# to set up your development environment.

# ============================================================================
# Core Development Tools
# ============================================================================
brew "git"                      # Version control
brew "zsh"                      # Shell (macOS includes it, but this ensures latest)
brew "fzf"                      # Fuzzy finder
brew "ripgrep"                  # Fast grep alternative (rg)
brew "fd"                       # Fast find alternative
brew "jq"                       # JSON processor
brew "yq"                       # YAML processor
brew "wget"                     # File downloader
brew "curl"                     # Transfer data with URLs
brew "htop"                     # Interactive process viewer
brew "watch"                    # Execute program periodically
brew "tree"                     # Display directories as trees

# ============================================================================
# Editor & Terminal
# ============================================================================
brew "neovim"                   # Modern Vim
brew "tmux"                     # Terminal multiplexer
brew "oh-my-posh"               # Prompt theme engine
cask "wezterm"                  # Terminal emulator

# ============================================================================
# Build Tools
# ============================================================================
brew "cmake"                    # Cross-platform build system
brew "ninja"                    # Small build system

# ============================================================================
# Programming Languages & Runtimes
# ============================================================================
brew "node"                     # JavaScript runtime
brew "python@3.14"              # Python 3
brew "go"                       # Go programming language

# ============================================================================
# Container Tools
# ============================================================================
brew "docker-compose"           # Multi-container Docker applications
cask "docker-desktop"           # Docker Desktop (includes daemon)

# ============================================================================
# GitHub & Git Tools
# ============================================================================
brew "gh"                       # GitHub CLI
brew "git-lfs"                  # Git Large File Storage

# ============================================================================
# macOS-Specific Applications
# ============================================================================
cask "aerospace"                # Tiling window manager for macOS
cask "1password-cli"            # Password manager CLI

# ============================================================================
# Optional: GUI Applications
# ============================================================================
# Uncomment if desired:
# cask "raycast"                # Spotlight alternative
